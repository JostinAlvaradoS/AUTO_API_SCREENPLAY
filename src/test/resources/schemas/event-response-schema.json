{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventResponse",
  "type": "object",
  "required": [
    "id",
    "name",
    "eventDate",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string"
    },
    "eventDate": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ]
    }
  }
}
